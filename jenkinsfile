pipeline {
    agent any

    environment {
        APP_NAME = "socialmedia4awsec2server"
        PORT = "2000"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/kwamasco23/SocialMedia4awsCc2Server.git'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh '''
                    docker stop $APP_NAME || true
                    docker rm $APP_NAME || true
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t $APP_NAME .
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                    docker run -d \
                        --name $APP_NAME \
                        -p 8009:2000 \
                        $APP_NAME
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    sleep 5
                    curl -f http://localhost:2000 || exit 1
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    docker ps
                '''
            }
        }
    }

    post {
        success {
            echo 'Deployment SUCCESS 🚀'
        }

        failure {
            echo 'Deployment FAILED ❌'
        }
    }
}