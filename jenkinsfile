pipeline {
    agent any

    environment {
        APP_NAME = "socialmedia4awsec2server"
        PORT = "2000"
    }

    stages {

        stage('Stop Old Container') {
            steps {
                sh '''
                    docker stop $APP_NAME || true
                    docker rm $APP_NAME || true
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t $APP_NAME .
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                    docker run -d \
                        --name $APP_NAME \
                        -p $PORT:$PORT \
                        $APP_NAME
                '''
            }
        }

        stage('Verify') {
            steps {
                sh '''
                    docker ps
                    curl -s http://localhost:$PORT || true
                '''
            }
        }
    }
}